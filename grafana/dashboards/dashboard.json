{
  "title": "DataWatch Pipeline Health",
  "timezone": "browser",
  "panels": [
    {
      "title": "Row Count Over Time",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "pipeline_last_batch_row_count",
          "legendFormat": "Rows"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "Total Anomalies",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "pipeline_anomaly_total"
        }
      ],
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 }
    },
    {
      "title": "Quarantine Size (Rows)",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "pipeline_quarantine_size"
        }
      ],
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 }
    },
    {
      "title": "Pipeline Health Score",
      "type": "gauge",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "100 - (pipeline_anomaly_total * 5)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "green", "value": 90 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    }
  ]
}
